<h1><% content_for(:title, "fichas") %></h1>

<div id="fichas">
  <% @fichas.each do |ficha| %>
    <div class='<%= cycle('bg-success-subtle', 'bg-light') %> shadow rounded mb-4'>
      <div class="p-2">
        <% if ficha.tipo == 'dieta' %>
          <%= link_to ficha_dietas_path(ficha), class: 'text-dark link-offset-2 link-underline link-underline-opacity-0' do %>
            <%= render ficha %>
          <% end %>
        <% else %>
          <%= link_to ficha_treinos_path(ficha), class: 'text-dark link-offset-2 link-underline link-underline-opacity-0' do %>
            <%= render ficha %>
          <% end %>
        <% end %>
        <%= link_to '+ Detalhes', ficha, class: 'btn btn-success-custom text-light' %>
      </div>
    </div>
  <% end %>
</div>

<div class="d-grid gap-2">
  <%= link_to "Nova ficha", new_ficha_path(@ficha), data: { controller: "bridge--nav-button", bridge_title: "+ ficha" }, class: 'btn btn-primary' %>
</div>
