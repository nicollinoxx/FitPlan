<div id="<%= dom_id ficha %>">
  <%= link_to ficha, class: 'link-dark link-offset-2 link-underline link-underline-opacity-0' do %>
      <div class="p-2">
        <div>
          <h2 class='fw-bold'><%= ficha.nome %></h2>
          <p> <strong>Descrição: </strong><%= ficha.descricao %></p>
        </div>
        <% if action_name == 'index' %>
          <div class='btn-toolbar'>
            <%= link_to 'Editar ficha', edit_ficha_path(ficha), class: 'btn btn-secondary me-2' %>
            <%= button_to 'Excluir ficha', ficha, method: :delete, data: {turbo_confirm: 'Você tem certeza? Todas os treinos ou dietas que pertencem a esta ficha serão apagados!'}, class: 'btn btn-danger' %>
          </div>
        <% end %>
      </div>
  <% end %>
</div>
