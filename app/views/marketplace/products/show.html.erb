<% content_for(:title, @product.title) %>

<div class="d-flex justify-content-between align-items-start mb-3 gap-3">
  <div>
    <h1 class="mb-1"><%= @product.title %></h1>
    <p class="text-muted mb-0"><%= @product.description %></p>
    <small class="text-muted"><%= @product.user.name %></small>
  </div>
</div>

<h2 class="h5"><%= t(".included_sheets") %></h2>
<div class="row">
  <% @product.product_items.each do |item| %>
    <%= render partial: "sheets/sheet_card", locals: { sheet: item.sheet } %>
  <% end %>
</div>

<div class="d-flex gap-2 mt-3">
  <% if @product.user != Current.user %>
    <%= button_to t(".import"), import_marketplace_product_path(@product), method: :post, class: "btn btn-success" %>
  <% end %>

  <%= link_to t(".back"), marketplace_products_path, class: "btn btn-outline-secondary" %>
</div>
