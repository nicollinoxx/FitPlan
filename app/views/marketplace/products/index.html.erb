<% content_for(:title, t(".title")) %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h1><%= t(".title") %></h1>
</div>

<div class="row">
  <% @products.each do |product| %>
    <div class="col-md-6 p-2">
      <div class="rounded shadow-sm border bg-body-tertiary p-3 h-100">
        <div class="d-flex justify-content-between gap-3">
          <div>
            <h2 class="h5 mb-1"><%= link_to product.title, marketplace_product_path(product), class: "text-decoration-none" %></h2>
            <p class="text-muted mb-2"><%= product.description.presence || t(".no_description") %></p>
          </div>
          <div class="text-end">
            <small class="text-muted"><%= product.user.name %></small>
          </div>
        </div>

        <div class="mt-3">
          <small class="text-muted d-block mb-2"><%= t(".sheets_count", count: product.product_items.size) %></small>
          <% product.product_items.each do |item| %>
            <div class="small text-muted"><%= item.sheet.name %></div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>
