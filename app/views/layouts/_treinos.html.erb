<div id="treinos">
  <% @ficha.treinos.each do |treino| %>
    <%= link_to treino, class: "link-dark link-offset-2 link-underline link-underline-opacity-0" do %>
      <%= render treino %>
    <% end %>

    <% if Treino %>
      <hr>
    <% end %>

  <% end %>
</div>

<div class="d-grid gap-2">
  <%= link_to "Novo treino", new_treino_path(ficha_id: @ficha.id), class: 'btn btn-primary' %>
</div>
