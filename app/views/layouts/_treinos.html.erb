<h1><% content_for(:title, 'Fichas de treinos') %></h1>

<% @ficha.treinos.each do |treino| %>
  <%= link_to ficha_treino_path(@ficha, treino), class: "link-dark link-offset-2 link-underline link-underline-opacity-0" do %>
    <%= render treino %>
  <% end %>
<% end %>

<div class="d-grid gap-2">
  <%= link_to "Novo treino", new_ficha_treino_path(@ficha), data: { controller: "bridge--nav-button", bridge_title: "+ Treino" }, class: 'btn btn-primary' %>
</div>
