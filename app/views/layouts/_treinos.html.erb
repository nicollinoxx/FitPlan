<div id="treinos">
  <% @ficha.treinos.each do |treino| %>
    <%= render treino %>
    <p>
      <%= link_to "Ver treino", treino, class: 'btn btn-secondary' %>
    </p>
    <% if Treino %>
      <hr>
    <% end %>
  <% end %>
</div>

<div class="d-grid gap-2">
  <%= link_to "Novo treino", new_treino_path(ficha_id: @ficha.id), class: 'btn btn-primary' %>
</div>
