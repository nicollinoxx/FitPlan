<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title || FitPlan ) %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", defer: true %>

    <% if turbo_native_app? %>
      <style>.hide-on-mobile { display: none; }</style>
    <% end %>
  </head>

  <body>
  <div class="hide-on-mobile">
    <div class="bg-success-custom">
      <h1 class='text-center text-white'>
        <%= content_for(:title || FitPlan ) %>
      </h1>
     <nav class="navbar navbar-expand-lg bg-body-tertiary">
        <div class="container-fluid">
          <%= link_to 'Inicio', root_path, class: 'navbar-brand'%>
          <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
          </button>
          <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav">
              <li class="nav-item">
                <%= link_to 'Fichas', fichas_path, class: 'nav-link link-dark'%>
              </li>
              <li class="nav-item">
                <%= link_to 'Dietas', fichas_diets_path, class: 'nav-link link-dark'%>
              </li>
              <li class="nav-item">
                <%= link_to 'Treinos', fichas_treinos_path, class: 'nav-link link-dark'%>
              </li>
            </ul>
          </div>
        </div>
      </nav>
    </div>
  </div>

    <div class="container">
        <% if notice.present? %>
          <div class="alert alert-success" role="alert" data-controller="bridge--flash-message">
            <%= notice %>
          </div>
        <% end %>

        <%= yield %>

    </div>
  </body>
</html>
