<!DOCTYPE html>
<html data-controller="theme">
  <head>
    <title><%= content_for(:title || FitPlan) %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <% if turbo_native_app? %>
      <style>.hide-on-mobile, h1 { display: none; }</style>
    <% end %>
  </head>

  <body>
    <%= render 'layouts/navbar' if Current.user.present? %>

    <%= turbo_stream_from "follow_notifications_#{Current.user.id}" if Current.user.present?  %>

    <div id="flash_container" class="position-sticky z-3" style="top: 8px;">
      <%= render 'layouts/flash_notice/notice', message: notice if notice.present?%>
    </div>

    <div class="container <%= 'mt-4' if turbo_native_app? %>">
      <%= yield %>
    </div>

    <%= render 'layouts/dialog' %>
  </body>
</html>
