<!DOCTYPE html>
<html data-controller="theme">
  <head>
    <title><%= content_for(:title || FitPlan) %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <% if turbo_native_app? %>
      <style>.hide-on-mobile, h1 { display: none; }</style>
    <% end %>
  </head>

  <body>
    <%= render 'layouts/navbar' if Current.user.present? %>

    <% if notice.present? %>
      <div class="container my-3 hide-on-mobile">
        <div class="alert alert-dark py-2 rounded" role="alert" data-controller="bridge--flash-message"><%= notice %></div>
      </div>
    <% end %>

    <div class="container <%= 'mt-4' if turbo_native_app? %>">
      <%= yield %>
    </div>

    <%= render 'layouts/dialog' %>
  </body>
</html>
