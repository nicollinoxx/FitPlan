<h1 class='text-center'><% content_for(:title, "Treinos") %></h1>

<% if @treinos.count == 0 %>
  <div class="alert alert-warning" role='alert'>
    Hum, parece que esta ficha ainda esta vazia
  </div>
<% end %>

<div id="treinos">
  <% @treinos.each do |treino| %>
    <%= render treino %>
  <% end %>
  <% if params[:treino_id] %>
    <%= link_to 'voltar', ficha_treinos_path(@ficha), class: 'hide-on-mobile link-primary' %>
  <% else %>
    <div class="d-grid gap-2">
      <%= link_to "Novo treino", new_ficha_treino_path(@ficha), data: { controller: "bridge--nav-button", bridge_title: "+ Treino" }, class: 'btn btn-primary' %>
    </div>
  <% end %>
</div>
