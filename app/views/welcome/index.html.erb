<% content_for(:title, t("welcome.title")) %>

<div class="d-flex flex-column min-vh-100 bg-light">
  <div class="d-flex justify-content-between align-items-center p-3 p-md-4">
    <div></div>
    <div>
      <%= render 'shared/language_dropdown' %>
    </div>
  </div>

  <div class="flex-grow-1 d-flex flex-column justify-content-center">
    <div class="container-lg">
      <div class="row align-items-center g-5">
        <div class="col-12 col-lg-6 text-center text-lg-start">
          <h1 class="fw-bold text-success display-4 mb-4">FITPLAN</h1>
          <p class="lead text-muted mb-5">
            <%= t("welcome.subtitle_html") %>
          </p>

          <div class="mb-5">
            <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center justify-content-lg-start">
              <%= link_to t("welcome.sign_in"), sign_in_path, class: "btn btn-success btn-lg px-5 py-3" %>
              <%= link_to t("welcome.sign_up"), sign_up_path, class: "btn btn-outline-success btn-lg px-5 py-3" %>
            </div>
            <p class="small text-muted mt-3 mb-0"><%= t("welcome.section_signup") %></p>
          </div>

          <div class="row g-4">
            <div class="col-12">
              <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-start">
                  <div class="d-flex align-items-start gap-3">
                    <div class="fs-3">📋</div>
                    <div>
                      <h6 class="text-success fw-semibold mb-2"><%= t("welcome.cards.training.title") %></h6>
                      <p class="small text-muted mb-0"><%= t("welcome.cards.training.text") %></p>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <div class="col-12">
              <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-start">
                  <div class="d-flex align-items-start gap-3">
                    <div class="fs-3">🥗</div>
                    <div>
                      <h6 class="text-success fw-semibold mb-2"><%= t("welcome.cards.diet.title") %></h6>
                      <p class="small text-muted mb-0"><%= t("welcome.cards.diet.text") %></p>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <div class="col-12">
              <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-start">
                  <div class="d-flex align-items-start gap-3">
                    <div class="fs-3">📈</div>
                    <div>
                      <h6 class="text-success fw-semibold mb-2"><%= t("welcome.cards.progress.title") %></h6>
                      <p class="small text-muted mb-0"><%= t("welcome.cards.progress.text") %></p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="col-12 col-lg-6 d-flex justify-content-center">
          <%= image_tag 'undraw/athletes_running.svg', class: 'img-fluid', style: 'max-width: 500px;' %>
        </div>
      </div>
    </div>
  </div>
</div>