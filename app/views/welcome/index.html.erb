<% content_for(:title, t("welcome.title")) %>

<div class="min-vh-100 d-flex align-items-center mt-4">
  <div class="row align-items-center w-100 m-0">

    <div class="col-12 col-lg-6 position-relative">
      <h1 class="fw-bold text-success display-4 mb-4 text-center">FITPLAN</h1>

      <div class="position-absolute top-0 end-0 z-3">
        <%= render 'shared/language_dropdown' %>
      </div>

      <p class="lead text-muted text-start">
        <%= t("welcome.subtitle_html") %>
      </p>

      <div class="mb-5 mt-4">
        <%= link_to t("welcome.sign_in"), sign_in_path, class: "btn btn-success w-100" %>

        <div class="mt-3">
          <p class="text-start small text-muted mb-1"><%= t("welcome.section_signup") %></p>
          <%= link_to t("welcome.sign_up"), sign_up_path, class: "btn btn-secondary w-100" %>
        </div>
      </div>

      <div class="d-flex flex-column gap-4 text-start">
        <div class="d-flex align-items-center gap-3 bg-body-tertiary py-2 px-3 rounded shadow-sm">
          <i class="bi bi-lightning-charge-fill fs-3"></i>
          <div>
            <h6 class="text-success fw-semibold mb-2"><%= t("welcome.cards.training.title") %></h6>
            <p class="small text-muted mb-0"><%= t("welcome.cards.training.text") %></p>
          </div>
        </div>

        <div class="d-flex align-items-center gap-3 bg-body-tertiary py-2 px-3 rounded shadow-sm">
          <i class="bi bi-suit-heart-fill fs-3"></i>
          <div>
            <h6 class="text-success fw-semibold mb-2"><%= t("welcome.cards.diet.title") %></h6>
            <p class="small text-muted mb-0"><%= t("welcome.cards.diet.text") %></p>
          </div>
        </div>

        <div class="d-flex align-items-center gap-3 bg-body-tertiary py-2 px-3 rounded shadow-sm">
          <i class="bi bi-graph-up-arrow fs-3"></i>
          <div>
            <h6 class="text-success fw-semibold mb-2"><%= t("welcome.cards.progress.title") %></h6>
            <p class="small text-muted mb-0"><%= t("welcome.cards.progress.text") %></p>
          </div>
        </div>
      </div>
    </div>

    <div class="col-12 col-lg-6 text-center mt-4 mb-5">
      <%= image_tag 'undraw/athletes_running.svg', alt: '', class: 'img-fluid' %>
    </div>
  </div>
</div>
