<% cache [sheet] do %>
  <div id="<%= dom_id sheet %>">
    <div class="d-flex align-items-center mb-2">
      <i class="bi <%= sheet.workout? ? 'bi-heart-pulse text-success' : 'bi-egg-fried text-warning' %> fs-3 me-2"></i>
      <div>
        <h2 class="h6 fw-semibold"><%= sheet.name %></h2>
        <div class="d-flex gap-2">
          <small class="badge <%= sheet_type_badge_class(sheet) %>">
            <%= t("enums.sheet.sheet_type.#{sheet.sheet_type}") %>
          </small>
          <small class="badge <%= visibility_badge_class(sheet) %>">
            <%= t("enums.sheet.visibility.#{sheet.visibility}") %>
          </small>
        </div>
      </div>
    </div>
    <p class="card-text text-muted fs-6"><%= sheet.description %></p>
  </div>
<% end %>
