<%= turbo_stream.replace :next_page_container, partial: "sheets/requests/request", collection: @page.records, as: :request %>

<% unless @page.last? %>
  <%= turbo_stream.append :paginables, partial: "shared/paginables/next_page_container", locals: { src: requests_path(page: @page.next_param, format: :turbo_stream) } %>
<% end %>
