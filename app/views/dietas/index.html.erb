<h1 class='text-center'><% content_for(:title, "Dietas") %></h1>

<% if @dietas.count == 0 %>
  <div class="alert alert-warning" role='alert'>
    Hum, parece que esta ficha ainda esta vazia
  </div>
<% end %>

<div id="diets">
  <% @dietas.each do |dieta| %>
    <%= render dieta %>
  <% end %>
</div>

<div class="d-grid gap-2">
  <%= link_to "Nova Dieta", new_ficha_dieta_path(@ficha), data: { controller: "bridge--nav-button", bridge_title: "+ Dieta" }, class: 'btn btn-primary' %>
</div>
