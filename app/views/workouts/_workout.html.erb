<div id="<%= dom_id workout %>" class="shadow rounded border">
  <div class="bg-success text-light bg-opacity-20 p-2 rounded-top">
    <h2 class="h6 mb-0 text-truncate">
      <i class="bi bi-activity me-1"></i>
      <% if action_name != 'show' %>
        <%= link_to workout.exercise, sheet_workout_path(@sheet, workout), class: 'text-light text-decoration-none' %>
      <% else %>
        <%= workout.exercise %>
      <% end %>
    </h2>
  </div>

  <div class="p-3">
    <div class="d-flex flex-wrap gap-2">
      <div class="border text-center p-2 rounded flex-grow-1" style="min-width: 45%">
        <p class="small text-muted mb-0"><i class="bi bi-repeat"></i> <%= t('series') %></p>
        <p class="fw-bold mb-0"><%= workout.series %></p>
      </div>

      <div class="border text-center p-2 rounded flex-grow-1" style="min-width: 45%">
        <p class="small text-muted mb-0"><i class="bi bi-arrow-repeat"></i> <%= t('repetitions') %></p>
        <p class="fw-bold mb-0"><%= workout.repetitions %></p>
      </div>

      <div class="border text-center p-2 rounded flex-grow-1" style="min-width: 45%">
        <p class="small text-muted mb-0"><i class="bi bi-stopwatch"></i> <%= t('interval') %></p>
        <p class="fw-bold mb-0"><%= workout.interval&.strftime("%M:%S") %></p>
      </div>

      <div class="border text-center p-2 rounded flex-grow-1" style="min-width: 45%">
        <p class="small text-muted mb-0"><i class="bi bi-weight"></i> <%= t('charge') %></p>
        <p class="fw-bold mb-0"><%= workout.charge %></p>
      </div>
    </div>

    <% if workout.video.attached? %>
      <div class="mt-3 text-center">
        <button class="btn btn-sm border" data-bs-toggle="collapse" data-bs-target="#v-<%= workout.id %>">
          <i class="bi bi-play-circle"></i> <%= t('show_video') %>
        </button>
        <div class="collapse mt-2" id="v-<%= workout.id %>">
          <div class="ratio ratio-16x9">
            <%= video_tag url_for(workout.video), controls: true, class: 'rounded' %>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <div class="border-top p-2 d-flex justify-content-between align-items-center">
    <div class="d-flex align-items-center gap-2">
      <%= button_to sheet_completions_path(@sheet), params: { completion: { workout_id: workout.id } }, class: 'btn btn-sm btn-success' do %>
        <i class="bi bi-check-lg me-1"></i><%= t('complete') %>
      <% end %>
      <% if count > 0 %>
        <span class="text-success fw-semibold small"><%= count %>x <%= t('today') %></span>
        <%= button_to sheet_completion_path(@sheet, last_completion), method: :delete, class: 'btn btn-sm btn-outline-secondary' do %>
          <i class="bi bi-arrow-counterclockwise"></i>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
