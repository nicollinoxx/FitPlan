<div id="<%= dom_id workout %>" class="shadow-sm bg-body-tertiary rounded border">
  <div class="<%= completion&.series_zero? ? 'bg-secondary' : 'bg-success' %> text-light bg-opacity-20 p-2 rounded-top d-flex justify-content-between align-items-center">
    <h2 class="h6 mb-0 text-truncate">
      <i class="bi bi-activity me-1"></i><%= workout.exercise %>
    </h2>

    <% unless action_name == 'show' %>
      <div class="d-flex gap-2">
        <%= link_to sheet_workout_path(@sheet, workout), data: { turbo_frame: "_top" }, class: "btn btn-sm btn-light" do %>
          <i class="bi bi-pencil-square"></i>
        <% end %>

        <%= workout_completion_button(@sheet, workout, completion) %>
      </div>
    <% end %>
  </div>

  <div class="p-3">
    <div class="d-flex flex-wrap gap-2">
      <div class="border text-center p-2 rounded flex-grow-1 position-relative
        <%= 'pulse-success' if params[:pulsed].to_i == workout.id %>" style="min-width: 45%">

        <%= workout_reset_button(@sheet, workout, completion) if action_name != 'show' %>
        <p class="small text-muted mb-0"><i class="bi bi-repeat"></i> <%= t('series') %></p>
        <p class="fw-bold mb-0"><%= completion&.remaining_series || workout.series %></p>
      </div>

      <div class="border text-center p-2 rounded flex-grow-1" style="min-width: 45%">
        <p class="small text-muted mb-0"><i class="bi bi-arrow-repeat"></i> <%= t('repetitions') %></p>
        <p class="fw-bold mb-0"><%= workout.repetitions %></p>
      </div>

      <div class="border text-center p-2 rounded flex-grow-1"
          data-controller="workouts--timer"
          data-workouts--timer-seconds-value="<%= workout.interval %>">

        <p class="small text-muted mb-0"><i class="bi bi-stopwatch"></i> <%= t('interval') %></p>

        <p class="fw-bold mb-0" data-workouts--timer-target="display">
          <%= format_interval(workout.interval) %>
        </p>

        <div class="d-flex justify-content-center gap-3">
          <button type="button" class="btn btn-sm text-success p-0" data-action="click->workouts--timer#start">
            <i class="bi bi-play-circle-fill fs-5"></i>
          </button>

          <button type="button" class="btn btn-sm text-warning p-0" data-action="click->workouts--timer#pause">
            <i class="bi bi-pause-circle-fill fs-5"></i>
          </button>

          <button type="button" class="btn btn-sm text-danger p-0" data-action="click->workouts--timer#stop">
            <i class="bi bi-arrow-counterclockwise fs-5"></i>
          </button>
        </div>
      </div>

      <div class="border text-center p-2 rounded flex-grow-1" style="min-width: 45%">
        <p class="small text-muted mb-0"><i class="bi bi-weight"></i> <%= t('charge') %></p>
        <p class="fw-bold mb-0"><%= t("workouts.form.options_charge.#{workout.charge}", default: workout.charge.to_s.humanize) %></p>
      </div>
    </div>

    <% if workout.video.attached? %>
      <div class="mt-3 text-center">
        <button class="btn btn-sm border" data-bs-toggle="collapse" data-bs-target="#v-<%= workout.id %>">
          <i class="bi bi-play-circle"></i> <%= t('show_video') %>
        </button>
        <div class="collapse mt-2" id="v-<%= workout.id %>">
          <div class="ratio ratio-16x9">
            <%= video_tag url_for(workout.video), controls: true, class: 'rounded' %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
