<div id="<%= dom_id workout %>" class="shadow rounded border">
  <div class="<%= completion&.remaining_series&.zero? ? 'bg-secondary' : 'bg-success' %> text-light bg-opacity-20 p-2 rounded-top d-flex justify-content-between align-items-center">
    <h2 class="h6 mb-0 text-truncate">
      <i class="bi bi-activity me-1"></i>
      <% if action_name != 'show' %>
        <%= link_to workout.exercise, sheet_workout_path(@sheet, workout), data: { turbo_frame: "_top" }, class: 'text-light text-decoration-none' %>
      <% else %>
        <%= workout.exercise %>
      <% end %>
    </h2>

    <%= workout_completion_button(@sheet, workout, completion) if action_name != 'show' %>
  </div>

  <div class="p-3">
    <div class="d-flex flex-wrap gap-2">
      <div class="border text-center p-2 rounded flex-grow-1 position-relative
        <%= 'pulse-success' if params[:pulsed].to_i == workout.id %>" style="min-width: 45%">

        <%= workout_reset_button(@sheet, workout, completion) if action_name != 'show' %>
        <p class="small text-muted mb-0"><i class="bi bi-repeat"></i> <%= t('series') %></p>
        <p class="fw-bold mb-0"><%= completion&.remaining_series || workout.series %></p>
      </div>

      <div class="border text-center p-2 rounded flex-grow-1" style="min-width: 45%">
        <p class="small text-muted mb-0"><i class="bi bi-arrow-repeat"></i> <%= t('repetitions') %></p>
        <p class="fw-bold mb-0"><%= workout.repetitions %></p>
      </div>

      <div class="border text-center p-2 rounded flex-grow-1" style="min-width: 45%">
        <p class="small text-muted mb-0"><i class="bi bi-stopwatch"></i> <%= t('interval') %></p>
        <p class="fw-bold mb-0"><%= workout.interval&.strftime("%M:%S") %></p>
      </div>

      <div class="border text-center p-2 rounded flex-grow-1" style="min-width: 45%">
        <p class="small text-muted mb-0"><i class="bi bi-weight"></i> <%= t('charge') %></p>
        <p class="fw-bold mb-0"><%= t("workouts.form.options_charge")[workout.charge.to_i] %></p>
      </div>
    </div>

    <% if workout.video.attached? %>
      <div class="mt-3 text-center">
        <button class="btn btn-sm border" data-bs-toggle="collapse" data-bs-target="#v-<%= workout.id %>">
          <i class="bi bi-play-circle"></i> <%= t('show_video') %>
        </button>
        <div class="collapse mt-2" id="v-<%= workout.id %>">
          <div class="ratio ratio-16x9">
            <%= video_tag url_for(workout.video), controls: true, class: 'rounded' %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
