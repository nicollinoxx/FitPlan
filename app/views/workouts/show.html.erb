<% content_for(:title, t('.title')) %>

<h1>
  <%= link_to sheet_workouts_path(@sheet), class: 'd-flex align-items-center gap-2 text-decoration-none text-body' do %>
    <i class="bi bi-arrow-left-short"></i><%= t('.title') %>
  <% end %>
</h1>

<div class="my-4">
  <%= render @workout, completion: @workout.completions.current_round.first %>
</div>

<div data-controller="bridge--menu">
  <div class="d-none" data-controller="bridge--nav-button" data-action="click->bridge--menu#show">Options</div>
  <div class='d-flex'>
    <div data-bridge--menu-target="title" class="d-none">Contact Options</div>
    <%= link_to t('edit'), edit_sheet_workout_path(@sheet, @workout), data: { bridge__menu_target: "item" }, class: 'btn btn-secondary me-4' %>
    <%= button_to t('destroy'), sheet_workout_path(@sheet, @workout), method: :delete, data: { bridge__menu_target: "item", 'turbo-confirm': t('message_destroy') }, class: 'btn btn-danger' %>
  </div>
</div>
