<div class="d-flex align-items-center justify-content-between">
  <div class="d-flex align-items-center gap-3 min-w-0">
    <% if @profile.avatar.attached? %>
      <%= image_tag @profile.avatar, class: "rounded-circle object-fit-cover flex-shrink-0 border-success-subtle border-3", width: 80, height: 80 %>
    <% else %>
      <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-secondary-subtle border border-success-subtle border-3"
            style="width: 80px; height: 80px;">
        <i class="bi bi-person-fill fs-3 text-secondary"></i>
      </div>
    <% end %>

    <div class="min-w-0">
      <p class="text-muted mb-0">@<%= @profile.handle %></p>
    </div>
  </div>

  <%= follow_toggle(@profile) %>
</div>
