<div class="container-lg py-4">
  <div class="d-flex align-items-center justify-content-between p-4 bg-body-tertiary rounded shadow-sm">
    <div class="d-flex align-items-center gap-3 min-w-0">
      <% if @profile.avatar.attached? %>
        <%= image_tag @profile.avatar, class: "rounded-circle object-fit-cover flex-shrink-0", width: 80, height: 80 %>
      <% else %>
        <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-secondary-subtle flex-shrink-0"
             style="width: 80px; height: 80px;">
          <i class="bi bi-person-fill fs-3 text-secondary"></i>
        </div>
      <% end %>

      <div class="min-w-0">
        <h4 class="fw-bold mb-1"><%= @profile.name %></h4>
        <p class="text-muted mb-0">@<%= @profile.handle %></p>
      </div>
    </div>

    <%= follow_toggle(@profile) %>
  </div>
</div>
