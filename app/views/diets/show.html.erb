<% content_for(:title, t('.title')) %>

<h1 class="mb-3">
  <%= link_to sheet_diets_path(@sheet), class: 'd-flex align-items-center gap-2 text-decoration-none text-body' do %>
    <i class="bi bi-arrow-left-short"></i><%= t('.title') %>
  <% end %>
</h1>

<div class="d-flex flex-column" style="min-height: calc(100vh - 160px);">
  <%= render @diet, completed: @diet.completions.current_round.exists? %>

  <%= render 'diets/analyze', percentage: @percentage unless @diet.calories.zero? %>

  <div class="mt-3" data-controller="bridge--menu">
    <div class="d-none" data-controller="bridge--nav-button" data-action="click->bridge--menu#show">Options</div>

    <div class="d-flex">
      <div data-bridge--menu-target="title" class="d-none d-flex gap-2">Contact Options</div>
      <%= link_to t('edit'), edit_sheet_diet_path(@sheet, @diet), data: { bridge__menu_target: "item" }, class: 'btn btn-secondary me-4' %>
      <%= button_to t('destroy'), sheet_diet_path(@sheet, @diet), method: :delete, data: { bridge__menu_target: "item", 'turbo-confirm': t('message_destroy') }, class: 'btn btn-danger' %>
    </div>
  </div>

  <%= image_tag 'undraw/cooking.svg', class: 'img-fluid mt-auto ms-auto' %>
</div>
